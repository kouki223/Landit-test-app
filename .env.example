# ===== Database (PostgreSQL + PostGIS) =====
POSTGRES_USER=landit
POSTGRES_PASSWORD=landit_password
POSTGRES_DB=landit
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== Backend (NestJS) =====
BACKEND_PORT=4000
# Google Geocoding API key (server-side, kept secret). Use your own free-tier key.
# A dummy value lets the app boot; reverse-geocoding returns a stubbed address without a real key.
GOOGLE_GEOCODING_API_KEY=dummy_geocoding_api_key

# ===== Frontend (Next.js) =====
# Public base URL the browser uses to reach the backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Google Maps JavaScript API key (exposed to the browser). Use your own free-tier key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=dummy_google_maps_api_key
